{
  "name": "orco-the-trader",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "orco": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "bun src/cli/main.tsx",
    "start": "bun dist/cli/main.js",
    "compile": "bun build --compile --minify --target=bun-linux-x64 src/cli/main.tsx --outfile dist/orco",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "test": "bun test",
    "check": "biome check . && tsc --noEmit && bun test"
  },
  "engines": {
    "bun": ">=1.3",
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/google": "^3.0.63",
    "@ai-sdk/groq": "^3.0.35",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/xai": "^3.0.82",
    "@openrouter/ai-sdk-provider": "^2.6.0",
    "ai": "^6.0.161",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "marked": "^18.0.0",
    "marked-terminal": "^7.3.0",
    "ollama-ai-provider-v2": "^3.5.0",
    "react": "^18.3.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "typescript": "^5.6.3"
  }
}
