{
  "name": "orco-the-trader",
  "version": "0.1.0",
  "description": "Terminal-native AI trading assistant for crypto — multi-provider LLMs, 28 native tools, live news + DeFi data, relative-strength + volume signals, event-driven backtesting, MCP support",
  "type": "module",
  "bin": {
    "orco": "dist/cli/main.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wideshreck/orco-the-trader.git"
  },
  "homepage": "https://github.com/wideshreck/orco-the-trader",
  "keywords": [
    "cli",
    "terminal",
    "ai",
    "agent",
    "llm",
    "crypto",
    "trading",
    "backtesting",
    "technical-analysis",
    "mcp",
    "anthropic",
    "openai"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc && node scripts/copy-skills.mjs",
    "dev": "bun src/cli/main.tsx",
    "start": "bun dist/cli/main.js",
    "compile": "bun build --compile --minify --target=bun-linux-x64 src/cli/main.tsx --outfile dist/orco",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "check": "biome check . && tsc --noEmit && bun test",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "bun": ">=1.3",
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/google": "^3.0.63",
    "@ai-sdk/groq": "^3.0.35",
    "@ai-sdk/mcp": "^1.0.36",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/xai": "^3.0.82",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^2.6.0",
    "ai": "^6.0.161",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "marked": "12",
    "marked-terminal": "^7.3.0",
    "ollama-ai-provider-v2": "^3.5.0",
    "react": "^18.3.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "typescript": "^5.6.3"
  }
}
